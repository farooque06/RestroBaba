{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": [
    "src/**/*",
    "prisma/**/*",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "src/__tests__/**/*",
    "prisma/seed.ts",
    "../../backend",
    "../../node_modules"
  ]
}