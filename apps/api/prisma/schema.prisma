generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  subdomain             String?                @unique
  shopCode              String?                @unique
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  categories            MenuCategory[]
  menus                 MenuItem[]
  orders                Order[]
  tables                Table[]
  users                 User[]
  inventoryItems        InventoryItem[]
  expenses              Expense[]
  inventoryTransactions InventoryTransaction[]
  activityLogs          ActivityLog[]
  customers             Customer[]
  shifts                FinancialShift[]
  staffTransactions     StaffTransaction[]
  useTax                Boolean                @default(false)
  taxRate               Float                  @default(0)
  useServiceCharge      Boolean                @default(false)
  serviceChargeRate     Float                  @default(0)

  // Nepal IRD Compliance Fields
  taxMode               String                 @default("NONE") // NONE, PAN_ONLY, VAT_REGISTERED
  panNumber             String?                // 9-digit PAN number
  vatNumber             String?                // VAT registration number (often same as PAN)
  businessAddress       String?                // Required on legal invoices
  businessPhone         String?                // Contact number on invoice
  invoicePrefix         String?                @default("INV") // e.g. "INV", "RB"
  nextInvoiceNumber     Int                    @default(1)      // Auto-incrementing fiscal invoice counter
  fiscalYearStart       String?                @default("Shrawan") // Nepal fiscal year start month

  plan                  String                 @default("SILVER") // SILVER, GOLD, DIAMOND
  planDuration          String?                @default("1m") // 1m, 3m, 12m
  planId                String?
  subscriptionPlan      SubscriptionPlan?      @relation(fields: [planId], references: [id])
  subscriptionStart     DateTime?              @default(now())
  subscriptionEnd       DateTime?
  paymentStatus         String                 @default("PAID") // PAID, PENDING, OVERDUE
  lastPaymentDate       DateTime?              @default(now())
  balance               Float                  @default(0) // Total outstanding debt
  qrCode                String?
  taxInvoices           TaxInvoice[]
  subscriptionPayments  SubscriptionPayment[]
}

model SubscriptionPlan {
  id   String @id @default(uuid())
  tier String // SILVER, GOLD, DIAMOND
  name String // e.g. "Early Bird Silver"

  // Base Prices
  monthlyPrice   Float @default(0)
  quarterlyPrice Float @default(0)
  yearlyPrice    Float @default(0)

  // Offer Prices (Promotional)
  offerMonthly   Float?
  offerQuarterly Float?
  offerYearly    Float?

  // Offer Labels
  discountLabel String? // e.g. "Save 33%"
  offerTag      String? // e.g. "Limited Time"

  // Limits
  maxStaff  Int @default(2)
  maxTables Int @default(10)

  // Features (Toggleable)
  hasKDS         Boolean @default(false)
  hasInventory   Boolean @default(true) // Basic for all
  hasAdvancedInv Boolean @default(false)
  hasAnalytics   Boolean @default(false)
  hasMultiUnit   Boolean @default(false)

  // Custom Features List (JSON stored as string or array if supported)
  features String[] // ["Standard Reports", "Priority Support"]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients Client[]
}

model User {
  id         String  @id @default(uuid())
  email      String  @unique
  password   String
  name       String
  role       String // SUPER_ADMIN, ADMIN, MANAGER, WAITER, CHEF
  pin        String? // 4-digit PIN for quick staff login
  totpSecret String? // TOTP secret for Google Authenticator 2FA
  isActive   Boolean @default(true)

  // Accountancy Fields
  salary      Float?    @default(0)
  salaryType  String?   @default("MONTHLY") // MONTHLY, DAILY
  joiningDate DateTime? @default(now())

  clientId              String? // Optional for SUPER_ADMIN
  client                Client?                @relation(fields: [clientId], references: [id])
  inventoryTransactions InventoryTransaction[]
  staffTransactions     StaffTransaction[]
  activityLogs          ActivityLog[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@unique([pin, clientId])
  @@index([clientId])
}

model StaffTransaction {
  id          String   @id @default(uuid())
  type        String // ADVANCE, PAYMENT, BONUS, FINE
  amount      Float
  description String?
  date        DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  shiftId String?
  shift   FinancialShift? @relation(fields: [shiftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clientId])
}

model MenuCategory {
  id        String     @id @default(uuid())
  name      String
  station   String?    @default("Kitchen") // Kitchen, Bar, Grill, etc.
  isDeleted Boolean    @default(false)
  deletedAt DateTime?
  clientId  String
  client    Client     @relation(fields: [clientId], references: [id])
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([name, clientId])
  @@index([clientId])
}

model MenuItem {
  id          String       @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  available   Boolean      @default(true)
  isDeleted   Boolean      @default(false)
  deletedAt   DateTime?
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orderItems  OrderItem[]
  recipe      RecipeItem[]
  variants    MenuItemVariant[]

  @@index([clientId])
  @@index([categoryId])
}

model MenuItemVariant {
  id          String       @id @default(uuid())
  name        String       // e.g. "30ml", "Full Plate", "Steam"
  price       Float        // The price for THIS specific variant
  menuItemId  String
  menuItem    MenuItem     @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  recipe      RecipeItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([menuItemId])
}

model InventoryItem {
  id           String                 @id @default(uuid())
  name         String
  unit         String // kg, liter, pcs, etc.
  quantity     Float                  @default(0)
  minThreshold Float                  @default(10) // For low stock alerts
  unitPrice    Float                  @default(0) // Cost per unit for profit calculation
  clientId     String
  client       Client                 @relation(fields: [clientId], references: [id])
  recipes      RecipeItem[]
  transactions InventoryTransaction[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([name, clientId])
  @@index([clientId])
}

model InventoryTransaction {
  id              String        @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  type            String // IN, OUT, WASTE, ORDER_DEDUCTION, ORDER_CANCELLED
  quantity        Float
  reason          String?
  userId          String? // Who performed the transaction
  user            User?         @relation(fields: [userId], references: [id])
  orderId         String? // Linked to an order if applicable
  order           Order?        @relation(fields: [orderId], references: [id])
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  createdAt       DateTime      @default(now())

  @@index([clientId])
  @@index([inventoryItemId])
  @@index([orderId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String // LOGIN, LOGOUT, PIN_CHANGE, ORDER_CREATED, STATUS_CHANGE, etc.
  details   String?
  type      String   @default("OPERATIONAL") // PLATFORM, OPERATIONAL
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
  @@index([type])
}

model RecipeItem {
  id              String        @id @default(uuid())
  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  variantId       String?        // NEW: Link to a specific variant if needed
  variant         MenuItemVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Float // Quantity of inventory item used for 1 portion of menu item
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([menuItemId, variantId, inventoryItemId]) // Allows same ingredient for same item but different variants
}

model Table {
  id        String   @id @default(uuid())
  number    String
  capacity  Int
  status    String   @default("Available") // Available, Occupied, Reserved
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([number, clientId])
  @@index([clientId])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  points    Int      @default(0)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, clientId])
  @@index([clientId])
}

model Order {
  id                  String                 @id @default(uuid())
  orderNumber         Int                    @default(autoincrement())
  status              String                 @default("Pending") // Pending, Cooking, Ready, Served, Paid, Cancelled
  type                String                 @default("DINE_IN") // DINE_IN, TAKEAWAY, DELIVERY
  totalAmount         Float
  tableId             String?
  table               Table?                 @relation(fields: [tableId], references: [id])
  customerId          String?
  customer            Customer?              @relation(fields: [customerId], references: [id])
  clientId            String
  client              Client                 @relation(fields: [clientId], references: [id])
  subtotal            Float                  @default(0)
  taxAmount           Float                  @default(0)
  serviceChargeAmount Float                  @default(0)
  paymentMethod       String? // Cash, Card, UPI, Split
  shiftId             String?
  shift               FinancialShift?        @relation(fields: [shiftId], references: [id])
  items               OrderItem[]
  payments            Payment[]
  transactions        InventoryTransaction[]
  taxInvoice          TaxInvoice?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([tableId])
  @@index([customerId])
  @@index([createdAt])
}

model OrderItem {
  id               String    @id @default(uuid())
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id])
  menuItemId       String
  menuItem         MenuItem        @relation(fields: [menuItemId], references: [id])
  variantId        String?         // NEW: Record which size/type was selected
  variant          MenuItemVariant? @relation(fields: [variantId], references: [id])
  quantity         Int
  price            Float
  notes            String?
  status           String    @default("Pending") // Pending, Cooking, Ready, Served, Waste
  cookingStartedAt DateTime?
  readyAt          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([orderId])
  @@index([menuItemId])
  @@index([variantId])
  @@index([status])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  amount    Float
  method    String // Cash, Card, UPI
  label     String? // "Person 1", "Guest A", etc.
  itemIds   String? // JSON array of orderItem IDs (for by-item splits)
  clientId  String
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([orderId])
}

model Expense {
  id          String          @id @default(uuid())
  description String
  amount      Float
  category    String // Ingredients, Salary, Utilities, Rent, Others
  date        DateTime        @default(now())
  shiftId     String?
  shift       FinancialShift? @relation(fields: [shiftId], references: [id])
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([clientId])
  @@index([date])
}

model FinancialShift {
  id         String    @id @default(uuid())
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  openedById String
  closedById String?
  status     String    @default("OPEN") // OPEN, CLOSED

  // Financial Data
  openingCash        Float     @default(0)
  closingCash        Float?    // Declared by manager
  expectedCash       Float?    // Calculated (opening + cash sales)
  totalSales         Float?    @default(0)
  totalExpenses      Float?    @default(0)
  cashSales          Float?    @default(0)
  cardSales          Float?    @default(0)
  upiSales           Float?    @default(0)
  totalTax           Float?    @default(0) // VAT Collected
  totalServiceCharge Float?    @default(0) // S.C. Collected
  taxableAmount      Float?    @default(0) // Sales excluding tax/SC (or including SC if taxable)

  clientId          String
  client            Client             @relation(fields: [clientId], references: [id])
  orders            Order[]
  expenses          Expense[]
  staffTransactions StaffTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
}

model RestaurantLead {
  id             String   @id @default(uuid())
  restaurantName String
  ownerName      String
  email          String
  phone          String
  location       String?
  message        String?
  status         String   @default("PENDING") // PENDING, CONTACTED, REJECTED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model TaxInvoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   // Sequential: "INV-0001", "INV-0002"
  fiscalYear      String   // "2081/82"
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])

  // Snapshot at time of billing (immutable for audit)
  subtotal        Float
  taxableAmount   Float    // subtotal + serviceCharge (base for VAT)
  taxRate         Float
  taxAmount       Float
  serviceCharge   Float    @default(0)
  totalAmount     Float

  // Seller info snapshot
  sellerName      String
  sellerPAN       String?
  sellerAddress   String?

  // Buyer info (for full invoices when requested)
  buyerName       String?
  buyerPAN        String?

  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  issuedAt        DateTime @default(now())

  @@index([clientId])
  @@index([fiscalYear])
  @@unique([invoiceNumber, clientId, fiscalYear])
}

model SubscriptionPayment {
  id            String   @id @default(uuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  
  planTier      String?  // Plan being paid for
  planDuration  String?  // 1m, 3m, 12m
  
  baseAmount    Float    @default(0)
  discount      Float    @default(0)
  totalPayable  Float    @default(0)
  amountPaid    Float    @default(0) // The actual cash received
  balance       Float    @default(0) // Remaining amount if partial
  
  method        String   // Cash, Bank Transfer, eSewa, Khalti, QR, etc.
  transactionId String?  // Reference ID from payment provider
  date          DateTime @default(now())
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clientId])
}
