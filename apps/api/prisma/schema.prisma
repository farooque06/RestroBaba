generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id             String         @id @default(uuid())
  name           String
  email          String         @unique
  subdomain      String?        @unique
  shopCode       String?        @unique
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  categories            MenuCategory[]
  menus                 MenuItem[]
  orders                Order[]
  tables                Table[]
  users                 User[]
  inventoryItems        InventoryItem[]
  expenses              Expense[]
  inventoryTransactions InventoryTransaction[]
  activityLogs          ActivityLog[]
  customers             Customer[]
  useTax                Boolean        @default(false)
  taxRate               Float          @default(0)
  useServiceCharge      Boolean        @default(false)
  serviceChargeRate     Float          @default(0)
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String
  role        String   // SUPER_ADMIN, ADMIN, WAITER, CHEF
  pin         String?  // 4-digit PIN for quick staff login
  totpSecret  String?  // TOTP secret for Google Authenticator 2FA
  isActive    Boolean  @default(true)
  clientId    String?  // Optional for SUPER_ADMIN
  client      Client?  @relation(fields: [clientId], references: [id])
  inventoryTransactions InventoryTransaction[]
  activityLogs          ActivityLog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pin, clientId])
}

model MenuCategory {
  id        String     @id @default(uuid())
  name      String
  station   String?    @default("Kitchen") // Kitchen, Bar, Grill, etc.
  clientId  String
  client    Client     @relation(fields: [clientId], references: [id])
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([name, clientId])
}

model MenuItem {
  id          String       @id @default(uuid())
  name        String
  description String?
  price       Float
  image       String?
  available   Boolean      @default(true)
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orderItems  OrderItem[]
  recipe      RecipeItem[]
}

model InventoryItem {
  id           String                 @id @default(uuid())
  name         String
  unit         String                 // kg, liter, pcs, etc.
  quantity     Float                  @default(0)
  minThreshold Float                  @default(10) // For low stock alerts
  unitPrice    Float                  @default(0) // Cost per unit for profit calculation
  clientId     String
  client       Client                 @relation(fields: [clientId], references: [id])
  recipes      RecipeItem[]
  transactions InventoryTransaction[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([name, clientId])
}

model InventoryTransaction {
  id              String        @id @default(uuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  type            String        // IN, OUT, WASTE, ORDER_DEDUCTION, ORDER_CANCELLED
  quantity        Float
  reason          String?
  userId          String?       // Who performed the transaction
  user            User?         @relation(fields: [userId], references: [id])
  orderId         String?       // Linked to an order if applicable
  order           Order?        @relation(fields: [orderId], references: [id])
  clientId        String
  client          Client        @relation(fields: [clientId], references: [id])
  createdAt       DateTime      @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String   // LOGIN, LOGOUT, PIN_CHANGE, ORDER_CREATED, STATUS_CHANGE, etc.
  details   String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  createdAt DateTime @default(now())
}

model RecipeItem {
  id              String        @id @default(uuid())
  menuItemId      String
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id])
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Float         // Quantity of inventory item used for 1 portion of menu item
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([menuItemId, inventoryItemId])
}

model Table {
  id        String   @id @default(uuid())
  number    String
  capacity  Int
  status    String   @default("Available") // Available, Occupied, Reserved
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([number, clientId])
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  points    Int      @default(0)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phone, clientId])
}

model Order {
  id          String      @id @default(uuid())
  orderNumber Int         @default(autoincrement())
  status      String      @default("Pending") // Pending, Cooking, Ready, Served, Paid, Cancelled
  totalAmount Float
  tableId     String?
  table       Table?      @relation(fields: [tableId], references: [id])
  customerId          String?
  customer            Customer?   @relation(fields: [customerId], references: [id])
  clientId            String
  client              Client      @relation(fields: [clientId], references: [id])
  subtotal            Float       @default(0)
  taxAmount           Float       @default(0)
  serviceChargeAmount Float       @default(0)
  items         OrderItem[]
  transactions  InventoryTransaction[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
  price      Float
  notes      String?
  status     String   @default("Pending") // Pending, Ready, Waste
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Float
  category    String   // Ingredients, Salary, Utilities, Rent, Others
  date        DateTime @default(now())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
